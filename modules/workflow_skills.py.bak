    def auto_backup_archive(self, source_folder: str = None, 
                          target_drive: str = None) -> Dict[str, Any]:
        """自动备份与归档工作流
        
        场景三：自动备份与归档
        当你插入移动硬盘，AI识别你的操作意图。
        自动对比硬盘内容和电脑"工作"文件夹的修改时间。
        将新增和修改的文件复制过去，并生成一份"备份日志.txt"放在硬盘根目录。
        备份完成后，安全弹出硬件并播放提示音。
        """
        logger.info("开始自动备份与归档工作流")
        
        workflow_id = f"backup_{int(time.time())}"
        
        # 确定源文件夹和目标驱动器
        if not source_folder:
            source_folder = str(Path.home() / "工作")
        
        if not target_drive:
            # 尝试查找可移动驱动器
            target_drive = self._find_removable_drive()
            if not target_drive:
                return {
                    "success": False,
                    "error": "未找到可移动驱动器，请插入U盘或移动硬盘"
                }
        
        # 创建工作流记录
        workflow_record = {
            "workflow_id": workflow_id,
            "type": "backup_archive",
            "source_folder": source_folder,
            "target_drive": target_drive,
            "start_time": datetime.now().isoformat(),
            "status": "running",
            "steps": [],
            "result": {}
        }
        
        self.active_workflows[workflow_id] = workflow_record
        
        # 启动工作流线程
        workflow_thread = threading.Thread(
            target=self._backup_archive_worker,
            args=(workflow_id, source_folder, target_drive),
            daemon=True
        )
        workflow_thread.start()
        
        return {
            "success": True,
            "workflow_id": workflow_id,
            "message": f"已启动自动备份工作流：{source_folder} -> {target_drive}",
            "status": "started"
        }
    
    def _backup_archive_worker(self, workflow_id: str, source_folder: str, target_drive: str):
        """备份工作流工作线程"""
        workflow = self.active_workflows[workflow_id]
        
        try:
            # 步骤1: 检查文件夹和驱动器
            workflow["steps"].append({
                "step": 1,
                "action": "check_paths",
                "start_time": datetime.now().isoformat()
            })
            
            source_path = Path(source_folder)
            target_path = Path(target_drive) / "Backups" / datetime.now().strftime("%Y%m%d")
            
            if not source_path.exists():
                raise FileNotFoundError(f"源文件夹不存在：{source_folder}")
            
            target_path.mkdir(parents=True, exist_ok=True)
            
            workflow["steps"][-1]["end_time"] = datetime.now().isoformat()
            workflow["steps"][-1]["source_exists"] = source_path.exists()
            workflow["steps"][-1]["target_created"] = target_path.exists()
            
            # 步骤2: 对比文件
            workflow["steps"].append({
                "step": 2,
                "action": "compare_files",
                "start_time": datetime.now().isoformat()
            })
            
            file_comparison = self._compare_files(source_path, target_path)
            
            workflow["steps"][-1]["end_time"] = datetime.now().isoformat()
            workflow["steps"][-1]["comparison"] = file_comparison
            
            # 步骤3: 复制文件
            workflow["steps"].append({
                "step": 3,
                "action": "copy_files",
                "start_time": datetime.now().isoformat()
            })
            
            copy_results = self._copy_files(file_comparison, source_path, target_path)
            
            workflow["steps"][-1]["end_time"] = datetime.now().isoformat()
            workflow["steps"][-1]["copy_results"] = copy_results
            
            # 步骤4: 生成备份日志
            workflow["steps"].append({
                "step": 4,
                "action": "generate_log",
                "start_time": datetime.now().isoformat()
            })
            
            log_file = self._generate_backup_log(file_comparison, copy_results, target_path)
            
            workflow["steps"][-1]["end_time"] = datetime.now().isoformat()
            workflow["steps"][-1]["log_file"] = log_file
            
            # 步骤5: 安全弹出（模拟）
            workflow["steps"].append({
                "step": 5,
                "action": "eject_drive",
                "start_time": datetime.now().isoformat()
            })
            
            eject_success = self._safely_eject_drive(target_drive)
            
            workflow["steps"][-1]["end_time"] = datetime.now().isoformat()
            workflow["steps"][-1]["eject_success"] = eject_success
            
            # 步骤6: 播放提示音（模拟）
            workflow["steps"].append({
                "step": 6,
                "action": "play_notification",
                "start_time": datetime.now().isoformat()
            })
            
            self._play_backup_completion_sound()
            
            workflow["steps"][-1]["end_time"] = datetime.now().isoformat()
            workflow["steps"][-1]["notification_played"] = True
            
            # 完成工作流
            workflow["status"] = "completed"
            workflow["end_time"] = datetime.now().isoformat()
            workflow["result"] = {
                "files_copied": copy_results["files_copied"],
                "total_size": copy_results["total_size"],
                "backup_complete": True,
                "log_file": log_file
            }
            
            logger.info(f"备份工作流完成：{workflow_id}")
            
        except Exception as e:
            logger.error(f"备份工作流出错: {e}")
            workflow["status"] = "error"
            workflow["error"] = str(e)
            workflow["end_time"] = datetime.now().isoformat()
        
        # 保存到历史
        self.workflow_history.append(workflow)
        self.save_workflow_data()
        
        # 从活跃工作流中移除
        if workflow_id in self.active_workflows:
            del self.active_workflows[workflow_id]
    
    def _find_removable_drive(self) -> Optional[str]:
        """查找可移动驱动器（模拟）"""
        # 模拟查找驱动器
        drives = ["D:", "E:", "F:", "G:"]
        
        for drive in drives:
            drive_path = Path(drive)
            if drive_path.exists():
                # 简单判断是否为可移动驱动器
                try:
                    # 这里可以检查驱动器属性
                    return str(drive_path)
                except:
                    continue
        
        return None
    
    def _compare_files(self, source_path: Path, target_path: Path) -> Dict[str, Any]:
        """对比文件"""
        logger.info("对比文件...")
        
        source_files = []
        for item in source_path.rglob("*"):
            if item.is_file():
                source_files.append({
                    "path": str(item.relative_to(source_path)),
                    "size": item.stat().st_size,
                    "modified": item.stat().st_mtime,
                    "full_path": str(item)
                })
        
        target_files = []
        if target_path.exists():
            for item in target_path.rglob("*"):
                if item.is_file():
                    target_files.append({
                        "path": str(item.relative_to(target_path)),
                        "size": item.stat().st_size,
                        "modified": item.stat().st_mtime,
                        "full_path": str(item)
                    })
        
        # 找出需要备份的文件
        files_to_backup = []
        for src_file in source_files:
            target_file = next((t for t in target_files if t["path"] == src_file["path"]), None)
            
            if not target_file:
                # 新文件
                files_to_backup.append({
                    "path": src_file["path"],
                    "reason": "new",
                    "size": src_file["size"]
                })
            elif src_file["modified"] > target_file["modified"]:
                # 修改过的文件
                files_to_backup.append({
                    "path": src_file["path"],
                    "reason": "modified",
                    "size": src_file["size"]
                })
        
        return {
            "source_files": len(source_files),
            "target_files": len(target_files),
            "files_to_backup": files_to_backup,
            "total_size": sum(f["size"] for f in files_to_backup)
        }
    
    def _copy_files(self, comparison: Dict[str, Any], 
                   source_path: Path, target_path: Path) -> Dict[str, Any]:
        """复制文件"""
        logger.info("复制文件...")
        
        files_copied = 0
        total_size = 0
        
        for file_info in comparison["files_to_backup"]:
            src_file = source_path / file_info["path"]
            dst_file = target_path / file_info["path"]
            
            # 创建目标目录
            dst_file.parent.mkdir(parents=True, exist_ok=True)
            
            # 复制文件
            try:
                shutil.copy2(src_file, dst_file)
                files_copied += 1
                total_size += file_info["size"]
                logger.debug(f"已复制：{file_info['path']}")
            except Exception as e:
                logger.error(f"复制文件失败 {file_info['path']}: {e}")
        
        return {
            "files_copied": files_copied,
            "total_files": len(comparison["files_to_backup"]),
            "total_size": total_size
        }
    
    def _generate_backup_log(self, comparison: Dict[str, Any], 
                           copy_results: Dict[str, Any], target_path: Path) -> str:
        """生成备份日志"""
        log_content = f"""备份日志
生成时间：{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}

备份统计：
- 源文件数量：{comparison['source_files']}
- 目标文件数量：{comparison['target_files']}
- 需要备份的文件：{len(comparison['files_to_backup'])}
- 实际复制的文件：{copy_results['files_copied']}
- 总数据量：{comparison['total_size'] / 1024 / 1024:.2f} MB

备份详情："""
        
        for file_info in comparison["files_to_backup"]:
            log_content += f"\n- {file_info['path']} ({file_info['reason']}, {file_info['size']} bytes)"
        
        log_file = target_path.parent / "备份日志.txt"
        with open(log_file, 'w', encoding='utf-8') as f:
            f.write(log_content)
        
        logger.info(f"备份日志已生成：{log_file}")
        return str(log_file)
    
    def _safely_eject_drive(self, drive_path: str) -> bool:
        """安全弹出驱动器（模拟）"""
        logger.info(f"安全弹出驱动器：{drive_path}")
        # 模拟安全弹出
        time.sleep(1)
        logger.info("驱动器已安全弹出")
        return True
    
    def _play_backup_completion_sound(self):
        """播放备份完成提示音（模拟）"""
        logger.info("播放备份完成提示音")
        # 可以调用系统声音或播放音频文件
    
    def get_active_workflows(self) -> Dict[str, Dict]:
        """获取活跃的工作流"""
        return self.active_workflows
    
    def get_workflow_history(self, limit: int = 10) -> List[Dict]:
        """获取工作流历史"""
        return self.workflow_history[-limit:] if self.workflow_history else []